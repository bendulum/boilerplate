{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 4,
  "useTabs": false,
  "printWidth": 160,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": [
        "*.html",
        "*.css"
      ],
      "options": {
        "tabWidth": 4,
        "singleQuote": false,
        "htmlWhitespaceSensitivity": "css"
      }
    }
  ]
}
