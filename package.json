{
  "name": "boilerplate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "parcel src/index.html --open",
    "build": "parcel build src/index.html --dist-dir dist",
    "preview": "npm run build && npx serve dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "worker:dev": "wrangler dev ./cfw/worker.js",
    "worker:deploy": "wrangler deploy ./cfw/worker.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^0.12.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@typescript-eslint/parser": "^8.30.0",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "parcel": "^2.16.4",
    "parcel-transformer-svelte": "^1.2.3",
    "posthtml": "^0.16.6",
    "posthtml-include": "^1.7.0",
    "svelte": "^5.27.0",
    "svelte-eslint-parser": "^1.1.0",
    "tailwindcss": "^4.1.0"
  }
}
